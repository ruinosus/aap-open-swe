# === LLM Provider (pick one) ===
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# === Model (optional, default: anthropic:claude-opus-4-6) ===
OPEN_SWE_MODEL=openai:gpt-4o

# === Sandbox (optional, default: langsmith) ===
SANDBOX_TYPE=local

# === GitHub App (required for GitHub trigger) ===
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
GITHUB_WEBHOOK_SECRET=

# === Default Repository ===
DEFAULT_REPO_OWNER=
DEFAULT_REPO_NAME=

# === GitHub Org Allowlist (comma-separated) ===
ALLOWED_GITHUB_ORGS=

# === LangSmith (required for cloud sandboxes and tracing) ===
LANGSMITH_API_KEY_PROD=
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=aap-open-swe

# === Linear (optional) ===
LINEAR_API_KEY=
LINEAR_WEBHOOK_SECRET=

# === Slack (optional) ===
SLACK_BOT_TOKEN=
SLACK_BOT_USER_ID=
SLACK_BOT_USERNAME=
SLACK_SIGNING_SECRET=

# === Token Encryption ===
# Generate with: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

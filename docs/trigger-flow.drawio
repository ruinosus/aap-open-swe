<mxGraphModel adaptiveColors="auto">
  <root>
    <mxCell id="0"/>
    <mxCell id="1" parent="0"/>

    <!-- Title -->
    <mxCell id="title" value="AAP Open SWE — Trigger Flow" style="text;fontSize=22;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
      <mxGeometry x="250" y="10" width="400" height="40" as="geometry"/>
    </mxCell>

    <!-- Triggers Zone -->
    <mxCell id="zone-triggers" value="" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;dashed=1;opacity=40;" vertex="1" parent="1">
      <mxGeometry x="20" y="70" width="280" height="400" as="geometry"/>
    </mxCell>
    <mxCell id="zone-triggers-label" value="Triggers" style="text;fontSize=16;fontStyle=1;fontColor=#2563eb;align=left;" vertex="1" parent="1">
      <mxGeometry x="30" y="75" width="100" height="25" as="geometry"/>
    </mxCell>

    <!-- Agent Zone -->
    <mxCell id="zone-agent" value="" style="rounded=1;fillColor=#e1d5e7;strokeColor=#9673a6;dashed=1;opacity=40;" vertex="1" parent="1">
      <mxGeometry x="380" y="70" width="240" height="400" as="geometry"/>
    </mxCell>
    <mxCell id="zone-agent-label" value="GitHub Actions Runner" style="text;fontSize=16;fontStyle=1;fontColor=#6d28d9;align=left;" vertex="1" parent="1">
      <mxGeometry x="390" y="75" width="220" height="25" as="geometry"/>
    </mxCell>

    <!-- Output Zone -->
    <mxCell id="zone-output" value="" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;dashed=1;opacity=40;" vertex="1" parent="1">
      <mxGeometry x="700" y="70" width="220" height="400" as="geometry"/>
    </mxCell>
    <mxCell id="zone-output-label" value="Output" style="text;fontSize=16;fontStyle=1;fontColor=#15803d;align=left;" vertex="1" parent="1">
      <mxGeometry x="710" y="75" width="100" height="25" as="geometry"/>
    </mxCell>

    <!-- Trigger 1: Comment mention -->
    <mxCell id="t1" value="@aap-open-swe&#xa;in issue comment" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="40" y="110" width="240" height="45" as="geometry"/>
    </mxCell>

    <!-- Trigger 2: Issue created -->
    <mxCell id="t2" value="Issue created with&#xa;@aap-open-swe" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="40" y="170" width="240" height="45" as="geometry"/>
    </mxCell>

    <!-- Trigger 3: Assigned -->
    <mxCell id="t3" value="Issue assigned to&#xa;aap-open-swe" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="40" y="230" width="240" height="45" as="geometry"/>
    </mxCell>

    <!-- Trigger 4: Label -->
    <mxCell id="t4" value="Label 'aap-open-swe'&#xa;added to issue" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
      <mxGeometry x="40" y="290" width="240" height="45" as="geometry"/>
    </mxCell>

    <!-- Trigger 5: PR comment -->
    <mxCell id="t5" value="@aap-open-swe&#xa;in PR comment" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="40" y="350" width="240" height="45" as="geometry"/>
    </mxCell>

    <!-- React emoji -->
    <mxCell id="s1" value="React with eyes" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="400" y="110" width="200" height="40" as="geometry"/>
    </mxCell>

    <!-- Checkout -->
    <mxCell id="s2" value="Checkout repo + install deps" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
      <mxGeometry x="400" y="170" width="200" height="40" as="geometry"/>
    </mxCell>

    <!-- Extract task -->
    <mxCell id="s3" value="Extract task from issue" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
      <mxGeometry x="400" y="230" width="200" height="40" as="geometry"/>
    </mxCell>

    <!-- Run agent -->
    <mxCell id="s4" value="Run Deep Agent&#xa;(GPT-4o / Claude)" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;strokeWidth=3;fontStyle=1;fontSize=14;" vertex="1" parent="1">
      <mxGeometry x="400" y="290" width="200" height="50" as="geometry"/>
    </mxCell>

    <!-- Decision -->
    <mxCell id="d1" value="Code&#xa;changes?" style="rhombus;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
      <mxGeometry x="430" y="365" width="140" height="90" as="geometry"/>
    </mxCell>

    <!-- Create PR -->
    <mxCell id="o1" value="Create draft PR" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=14;" vertex="1" parent="1">
      <mxGeometry x="720" y="120" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- Comment with link -->
    <mxCell id="o2" value="Comment on issue&#xa;with PR link" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
      <mxGeometry x="720" y="200" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- No changes -->
    <mxCell id="o3" value="Comment:&#xa;no changes needed" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="1">
      <mxGeometry x="720" y="380" width="180" height="50" as="geometry"/>
    </mxCell>

    <!-- Arrows: triggers to pipeline -->
    <mxCell id="at1" edge="1" source="t1" target="s1" parent="1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6c8ebf;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="at2" edge="1" source="t2" target="s1" parent="1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6c8ebf;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="at3" edge="1" source="t3" target="s1" parent="1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6c8ebf;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="at4" edge="1" source="t4" target="s1" parent="1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#6c8ebf;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="at5" edge="1" source="t5" target="s1" parent="1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#d6b656;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Arrows: pipeline steps -->
    <mxCell id="as1" edge="1" source="s1" target="s2" parent="1" style="edgeStyle=orthogonalEdgeStyle;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="as2" edge="1" source="s2" target="s3" parent="1" style="edgeStyle=orthogonalEdgeStyle;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="as3" edge="1" source="s3" target="s4" parent="1" style="edgeStyle=orthogonalEdgeStyle;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
    <mxCell id="as4" edge="1" source="s4" target="d1" parent="1" style="edgeStyle=orthogonalEdgeStyle;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Decision: yes -->
    <mxCell id="ay" value="yes" edge="1" source="d1" target="o1" parent="1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#82b366;fontColor=#15803d;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- PR to comment -->
    <mxCell id="ao1" edge="1" source="o1" target="o2" parent="1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#82b366;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>

    <!-- Decision: no -->
    <mxCell id="an" value="no" edge="1" source="d1" target="o3" parent="1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#b85450;fontColor=#b85450;">
      <mxGeometry relative="1" as="geometry"/>
    </mxCell>
  </root>
</mxGraphModel>
